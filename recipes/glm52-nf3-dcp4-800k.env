# GLM-5.2 NF3-Hybrid — 🧠 CONTEXT LANE (DCP4) — 4× DGX Spark launch env
# TP4 + DCP4 ag_rs interleave 1: every sequence's KV cache is sharded across
# all 4 Sparks → 4× the pool, at the cost of cross-node gathers on all 78
# layers every decode step. Measured KV pool: 876,588 tokens.
# 800K max-model-len bench: PENDING (booting). 240K/k=5 first-boot numbers in README.

IMAGE=vllm-nf3-hybrid:probe
MODEL_PATH=/var/tmp/models/glm52-nf3-hybrid
SERVED_MODEL_NAME=glm-5.2
PORT=8210

TENSOR_PARALLEL_SIZE=4
DECODE_CONTEXT_PARALLEL_SIZE=4
DCP_COMM_BACKEND=ag_rs
DCP_KV_CACHE_INTERLEAVE_SIZE=1

QUANTIZATION=modelopt_fp4

KV_CACHE_DTYPE=fp8
MAX_MODEL_LEN=800000
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=4096          # NF3 graph capture breaks below 2048 — do not lower
MAX_CUDAGRAPH_CAPTURE_SIZE=32        # must cover seqs*(1+4) = 20 with MTP-4
GPU_MEMORY_UTILIZATION=0.88          # GB10 unified memory — author's 0.96 is dedicated-VRAM territory
ATTENTION_BACKEND=B12X_MLA_SPARSE
MOE_BACKEND=b12x
LOAD_FORMAT=fastsafetensors
ASYNC_SCHEDULING=1
ENABLE_CHUNKED_PREFILL=1
ENABLE_PREFIX_CACHING=1

# MTP-4 speculative (first boot ran k=5, accept 3.3–3.7)
SPECULATIVE_CONFIG={"method":"mtp","num_speculative_tokens":4,"moe_backend":"b12x","draft_sample_method":"probabilistic"}

# tool-calling + reasoning ON FROM FIRST BOOT (lesson learned twice)
REASONING_PARSER=glm45
TOOL_CALL_PARSER=glm47
ENABLE_AUTO_TOOL_CHOICE=1

# NOTE: no HF_OVERRIDES_JSON needed — serve.sh's built-in INDEX_TOPK_PATTERN default is correct.

# --- container env ---
CUTE_DSL_ARCH=sm_121a                # THE port: author ships sm_120a
VLLM_USE_V2_MODEL_RUNNER=1
VLLM_USE_B12X_FP8_GEMM=1
VLLM_USE_B12X_MOE=1
VLLM_USE_B12X_SPARSE_INDEXER=1
VLLM_DCP_GLOBAL_TOPK=1
VLLM_DCP_SHARD_DRAFT=1               # mandatory for MTP draft KV under DCP
B12X_W4A16_TC_DECODE=1
B12X_MOE_FORCE_A16=1
B12X_DENSE_SPLITK_TURBO=1
# hybrid loader knobs (v2)
HYBRID_TIER=both
HYBRID_KEPT=b12x_nf3
HYBRID_NF3=b12x_nf3
HYBRID_B12X_MAX_TOKENS=4096
HYBRID_MXFP8_NATIVE=1
# real path to the tier json inside our image (loader hardcodes author's /opt/venv layout)
HYBRID_MXFP8_TIER_JSON=/usr/local/lib/python3.12/dist-packages/mxfp8_tier.json

# --- fabric (EDIT FOR YOUR NETWORK — these are our 4-Spark fabric values) ---
HEAD_IP=192.168.192.1
WORKER_IPS="192.168.192.2 192.168.192.3 192.168.192.4"
SSH_KEY=/home/tonyspark1/.ssh/id_ed25519_shared
HS_IFACE=enp1s0f0np0
NCCL_IB_HCA=rocep1s0f0

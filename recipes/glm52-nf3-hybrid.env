# GLM-5.2 NF3-Hybrid — 4× DGX Spark launch env (DRAFT, pre-first-boot)
# Adapted from madeby561's single-box docker-compose (4× RTX PRO 6000) to our
# Ray 4-node TP4+DCP4 launch pattern (same infra as our 655K QuantTrio shape).
# First boot replicates the author's shape conservatively; context scaling comes after.

IMAGE=vllm-nf3-hybrid:probe
MODEL_PATH=/var/tmp/models/glm52-nf3-hybrid
SERVED_MODEL_NAME=glm-5.2
PORT=8210

TENSOR_PARALLEL_SIZE=4
DECODE_CONTEXT_PARALLEL_SIZE=4
DCP_COMM_BACKEND=ag_rs
DCP_KV_CACHE_INTERLEAVE_SIZE=1

# author: fp8 KV (not fp8_ds_mla). 240K on his 384GB; we scale up after first clean boot.
KV_CACHE_DTYPE=fp8
MAX_MODEL_LEN=240000
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=4096          # NF3 graph capture breaks below 2048 — do not lower
MAX_CUDAGRAPH_CAPTURE_SIZE=32        # must cover seqs*(1+5) = 24 with MTP-5
GPU_MEMORY_UTILIZATION=0.88          # GB10 unified memory — author's 0.96 is dedicated-VRAM territory
ATTENTION_BACKEND=B12X_MLA_SPARSE
MOE_BACKEND=b12x
LOAD_FORMAT=fastsafetensors
ASYNC_SCHEDULING=1
ENABLE_CHUNKED_PREFILL=1
ENABLE_PREFIX_CACHING=1

# MTP-5 speculative (author's config; our 655K shape ran k=3 — expect accept ~3)
SPECULATIVE_CONFIG={"method":"mtp","num_speculative_tokens":5,"moe_backend":"b12x","draft_sample_method":"probabilistic"}

# tool-calling + reasoning ON FROM FIRST BOOT (lesson learned twice)
REASONING_PARSER=glm45
TOOL_CALL_PARSER=glm47
ENABLE_AUTO_TOOL_CHOICE=1

# DSA sparse attention overrides (until upstream reads pattern from model config)
HF_OVERRIDES_JSON={"use_index_cache":true,"index_topk_pattern":"FFFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSS"}

# --- container env ---
CUTE_DSL_ARCH=sm_121a                # THE port: author ships sm_120a
VLLM_USE_V2_MODEL_RUNNER=1
VLLM_USE_B12X_FP8_GEMM=1
VLLM_USE_B12X_MOE=1
VLLM_USE_B12X_SPARSE_INDEXER=1
VLLM_DCP_GLOBAL_TOPK=1
VLLM_DCP_SHARD_DRAFT=1               # mandatory for MTP draft KV under DCP
B12X_W4A16_TC_DECODE=1
B12X_MOE_FORCE_A16=1
B12X_DENSE_SPLITK_TURBO=1
# hybrid loader knobs (v2)
HYBRID_TIER=both
HYBRID_KEPT=b12x_nf3
HYBRID_NF3=b12x_nf3
HYBRID_B12X_MAX_TOKENS=4096
HYBRID_MXFP8_NATIVE=1
